<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO">
  <Properties>
    <Property name="name">imagey-server</Property>
  </Properties>
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="[%d{HH:mm:ss.SSS}][%highlight{%-5level}][%15.15t][%30.30logger] %msg%n"/>
    </Console>
    <RollingFile name="DailyLogFile" fileName="logs/${name}.log"
                 filePattern="logs/${name}-%d{yyyy-MM-dd}-%i.log.gz">
      <PatternLayout pattern="[%d{HH:mm:ss.SSS}][%-5level][%15.15t][%30.30logger] %msg%n"/>
      <Policies>
        <TimeBasedTriggeringPolicy />
        <SizeBasedTriggeringPolicy size="50 MB"/>
      </Policies>
    </RollingFile>
  </Appenders>
  <Loggers>
    <Logger name="cloud.imagey" level="INFO" />
    
    <Root level="INFO">
      <!--<AppenderRef ref="Console"/>-->
      <AppenderRef ref="DailyLogFile"/>
    </Root>
  </Loggers>
</Configuration>
