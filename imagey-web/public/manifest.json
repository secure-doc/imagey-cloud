{
  "id": "imagey",
  "name": "Imagey - Your image vault",
  "short_name": "Imagey",
  "description": "Store and share your images and documents safely.",
  "start_url": "/",
  "display": "standalone",
  "theme_color": "#ffffff",
  "background_color": "#ffffff",
  "icons": [
    {
      "src": "imagey192.png",
      "type": "image/png",
      "sizes": "192x192"
    },
    {
      "src": "imagey512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any maskable"
    },
    {
      "src": "imagey.svg",
      "type": "image/svg+xml",
      "sizes": "any"
    }
  ],
  "share_target": {
    "action": "/upload",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "files": [
        {
          "name": "images",
          "accept": ["image/*", "video/*"]
        }
      ]
    }
  },
  "shortcuts": [
    {
      "name": "Images",
      "url": "/images",
      "icons": [
        {
          "src": "imagey192.png",
          "type": "image/png",
          "sizes": "192x192"
        },
        {
          "src": "imagey512.png",
          "type": "image/png",
          "sizes": "512x512",
          "purpose": "any maskable"
        },
        {
          "src": "imagey.svg",
          "type": "image/svg+xml",
          "sizes": "any"
        }
      ]
    },
    {
      "name": "Chats",
      "url": "/chats"
    }
  ]
}
